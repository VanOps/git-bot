# The ID of your GitHub App
APP_ID=
WEBHOOK_SECRET=development

# Use `trace` to get verbose logging or `info` to show less
LOG_LEVEL=debug

# Go to https://smee.io/new set this to the URL that you are redirected to.
WEBHOOK_PROXY_URL=

# MongoDB connection string (Docker Compose service name = mongo)
DATABASE_URL=mongodb://mongo:27017/probot_metrics

# Label name that triggers an incident record (default: incident)
INCIDENT_LABEL=incident

# Release Notes check – bloquea el merge si el PR no incluye la sección indicada
# RELEASE_NOTES_HEADER=## Release Notes
# RELEASE_NOTES_REQUIRED=true

# Label-based actions – etiqueta que bloquea el merge de un PR
# DONTMERGE_LABEL=DONTMERGE

# Grafana credentials (docker-compose)
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme
