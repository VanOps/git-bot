      {
        "name": "repo",
        "label": "Repositorio",
        "type": "query",
        "datasource": {
          "type": "yesoreyeram-infinity-datasource",
          "uid": "infinity-dora"
        },
        "definition": "http://probot:3000/metrics/workflows/repos",
        "query": {
          "refId": "StandardVariableQuery",
          "type": "json",
          "source": "url",
          "url": "http://probot:3000/metrics/workflows/repos?days=${days}",
          "root_selector": "",
          "columns": [
            { "selector": "text",  "text": "__text",  "type": "string" },
            { "selector": "value", "text": "__value", "type": "string" }
          ],
          "parser": "backend",
          "url_options": { "method": "GET", "data": "" },
          "format": "table"
        },
        "current": {},
        "options": [],
        "refresh": 1,
        "includeAll": true,
        "allValue": "",
        "multi": false,
        "hide": 0,
        "sort": 1
      },
      {
        "name": "workflow",
        "label": "Workflow",
