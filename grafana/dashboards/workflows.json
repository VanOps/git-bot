    {
      "id": 11,
      "type": "timeseries",
      "title": "Evolución histórica: Éxitos vs Fracasos",
      "description": "Tendencia diaria de ejecuciones exitosas y fallidas",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
