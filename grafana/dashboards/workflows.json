  "panels": [

    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "## Workflow Statistics  •  últimos `$days` días\nTodos los workflows de GitHub Actions · filtrado por **repo**: `$repo` · **workflow**: `$workflow`"
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Total de ejecuciones",
      "description": "Número total de check suites completados en el período",
      "gridPos": { "x": 0, "y": 2, "w": 6, "h": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "/^total_runs$/",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity-dora" },
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://probot:3000/metrics/workflows/summary?days=${days}&repo=${repo}&workflow=${workflow}",
          "format": "table",
          "root_selector": "",
          "columns": [
            { "selector": "total_runs",   "text": "total_runs",   "type": "number" },
            { "selector": "success_runs", "text": "success_runs", "type": "number" },
            { "selector": "failed_runs",  "text": "failed_runs",  "type": "number" },
            { "selector": "success_rate_pct", "text": "success_rate_pct", "type": "number" },
            { "selector": "avg_duration_min", "text": "avg_duration_min", "type": "number" }
          ],
          "parser": "backend",
          "url_options": { "method": "GET", "data": "" }
        }
      ]
    },

